local nCount = 0
local typeColors = {
    info    = Color3.fromRGB(80, 140, 255),
    success = Color3.fromRGB(80, 210, 130),
    warning = Color3.fromRGB(255, 185, 60),
    error   = Color3.fromRGB(255, 75, 75),
}

local function Notify(title, body, ntype, dur)
    ntype = ntype or "info"
    dur   = dur or 4
    nCount += 1
    local accent = typeColors[ntype] or typeColors.info

    local card = Instance.new("Frame")
    card.LayoutOrder = nCount
    card.Size = UDim2.new(1, 0, 0, 62)
    card.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    card.BackgroundTransparency = 1
    card.BorderSizePixel = 0
    card.ClipsDescendants = true
    card.Parent = NotifHolder
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, 3, 1, 0)
    bar.BackgroundColor3 = accent
    bar.BackgroundTransparency = 1
    bar.BorderSizePixel = 0
    bar.Parent = card
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 6)

    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, 12)
    pad.PaddingRight = UDim.new(0, 10)
    pad.PaddingTop = UDim.new(0, 8)
    pad.Parent = card

    local tl = Instance.new("TextLabel")
    tl.Size = UDim2.new(1, 0, 0, 16)
    tl.BackgroundTransparency = 1
    tl.Text = title
    tl.TextColor3 = Color3.new(1, 1, 1)
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 13
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.TextTransparency = 1
    tl.Parent = card

    local bl = Instance.new("TextLabel")
    bl.Size = UDim2.new(1, 0, 0, 28)
    bl.Position = UDim2.new(0, 0, 0, 18)
    bl.BackgroundTransparency = 1
    bl.Text = body or ""
    bl.TextColor3 = Color3.fromRGB(185, 185, 185)
    bl.Font = Enum.Font.Gotham
    bl.TextSize = 12
    bl.TextWrapped = true
    bl.TextXAlignment = Enum.TextXAlignment.Left
    bl.TextTransparency = 1
    bl.Parent = card

    local ti = TweenInfo.new(0.2, Enum.EasingStyle.Quad)
    TweenService:Create(card, ti, {BackgroundTransparency = 0}):Play()
    TweenService:Create(bar,  ti, {BackgroundTransparency = 0}):Play()
    TweenService:Create(tl,   ti, {TextTransparency = 0}):Play()
    TweenService:Create(bl,   ti, {TextTransparency = 0}):Play()

    task.delay(dur, function()
        if not card.Parent then return end
        local fo = TweenInfo.new(0.25)
        TweenService:Create(card, fo, {BackgroundTransparency = 1}):Play()
        TweenService:Create(bar,  fo, {BackgroundTransparency = 1}):Play()
        TweenService:Create(tl,   fo, {TextTransparency = 1}):Play()
        TweenService:Create(bl,   fo, {TextTransparency = 1}):Play()
        task.wait(0.25)
        TweenService:Create(card, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, 0)}):Play()
        task.wait(0.2)
        card:Destroy()
    end)
end

