local HighlightEnabled = false

local function removeHighlights()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then
            local h = p.Character:FindFirstChild("PHLight")
            if h then h:Destroy() end
        end
    end
end

local function applyHighlight(char, plr)
    if not HighlightEnabled then return end
    local old = char:FindFirstChild("PHLight")
    if old then old:Destroy() end
    if not plr.Team then return end

    local col
    if plr.Team.Name == "Department of Corrections" then
        col = Color3.fromRGB(0, 120, 255)
    elseif plr.Team.Name == "State Police" then
        col = Color3.fromRGB(255, 255, 255)
    else
        return
    end

    local h = Instance.new("Highlight")
    h.Name = "PHLight"
    h.FillColor = col
    h.FillTransparency = 0.4
    h.OutlineTransparency = 1
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent = char
end

